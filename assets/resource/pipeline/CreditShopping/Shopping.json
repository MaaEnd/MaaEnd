    "CreditShippingCanNotToBuy": {
        "desc": "刷新流程中无法购买",
        "enabled": false,
        "recognition": "Or",
        "any_of": [
            "AutoGetCredits",
            "CanNotFlash"
        ],
        "next": [
            "CreditShoppingNothingToBuy"
        ],
        "focus": {
            "Node.Action.Succeeded": "信用点不足"
        }
    },
    "RefreshItem": {
        "desc": "刷新商品",
        "enabled": false,
        "recognition": "And",

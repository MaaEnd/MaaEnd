//节点从Start进入，开始前要确保农田已被标记
//节点从Exit离开，这里关联下一个阶段的节点，里面的无限循环需要靠Maptracker检测坐标来退出
{ //节点出入口
    "_AutoEcoFarmMoveAndWorkStart": {
        "doc": "这块代码的目的是按下移动键，一边移动一边识别收菜菜单，识别到了就停下，点击收菜/播种/浇水",
        "next": [
            "_AutoEcoFarmJump"
        ]
    },
    "_AutoEcoFarmMoveAndWorkExit": {
        "next": [
            //在开启随机查找后会循环3次该任务增加全收集的概率
            "_AutoEcoFarmFindValleyIVEcoFarmAny",
            "AutoEcoFarmMain"
        ]
    }
    //内部节点
    ,
    "_AutoEcoFarmJump": {
        "doc": "往前跳，防止被卡住，先按下w",
        "action": {
            "type": "KeyDown",
            "param": {
                "key": 87 //w键
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmJump2"
        ]
    },
    "_AutoEcoFarmJump2": {
        "doc": "按一下空格",
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 32 //空格键
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmJump3"
        ]
    },
    "_AutoEcoFarmJump3": {
        "doc": "松开w",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 87 //w键
            }
        },
        //稍微加点延迟保证停稳
        "post_delay": 200,
        "next": [
            "_AutoEcoFarmFindMenuLoop",
            "_AutoEcoFarmMoveToTargetErr"
        ]
    },
    "_AutoEcoFarmFindMenuLoop": {
        "doc": "循环识别菜单",
        //最大连跑60秒，超过就直接结束任务
        "max_hit": 120,
        "next": [
            //先判断标记还在不在，不在的话找菜单
            "_AutoEcoFarmNoTarget",
            //识别失败的情况下判断是否还在农场内，如果不在则证明跑出农场了，结束该子任务
            "_AutoEcoFarmFindMenuIcon",
            "_AutoEcoFarmInAnyFarm",
            //不在的话结束任务
            "_AutoEcoFarmCancelMove"
        ]
    },
    "_AutoEcoFarmNoTarget": {
        "doc": "确定农场标记还在不在屏幕中，如果不在的话就结束",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    420,
                    100,
                    440,
                    300
                ],
                "template": "AutoEcoFarm/AutoEcoFarmFarmland.png",
                "threshold": 0.4
            }
        },
        "inverse": true,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            //如果找不到标记了就结束任务了
            "_AutoEcoFarmCancelMove"
        ]
    },
    "_AutoEcoFarmInAnyFarm": {
        "doc": "确认是否在任意农场内",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "_AutoEcoFarmInValleyIVFarm",
                    "_AutoEcoFarmInWulinFarm"
                ]
            }
        },
        "next": [
            "_AutoEcoFarmJump"
        ]
    },
    "_AutoEcoFarmInAnyFarmLoop": {
        "doc": "确认是否在任意农场内",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "_AutoEcoFarmInValleyIVFarm",
                    "_AutoEcoFarmInWulinFarm"
                ]
            }
        },
        "next": [
            "_AutoEcoFarmInAnyFarmLoop",
            "AutoEcoFarmExit"
        ]
    },
    "_AutoEcoFarmInValleyIVFarm": {
        "doc": "确认是否在谷地农场内",
        "recognition": "Custom",
        "custom_recognition": "MapTrackerAssertLocation",
        "custom_recognition_param": {
            "expected": [
                {
                    "map_name": "map01_lv005",
                    "target": [
                        551,
                        322,
                        23,
                        23
                    ]
                }
            ],
            "precision": 0.8
        }
    },
    "_AutoEcoFarmInWulinFarm": {
        "doc": "确认是否在武陵农场内",
        "recognition": "Custom",
        "custom_recognition": "MapTrackerAssertLocation",
        "custom_recognition_param": {
            "expected": [
                {
                    "map_name": "map02_lv002",
                    "target": [
                        413,
                        164,
                        33,
                        32
                    ]
                }
            ],
            "precision": 0.8
        }
    },
    "_AutoEcoFarmFindMenuIcon": {
        "doc": "寻找采集、播种、浇水的文字",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    806,
                    340,
                    266,
                    266
                ],
                "expected": [
                    "收获|育种|浇水"
                ],
                "threshold": 0.7
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 70 //F键
            }
        },
        "next": [
            "_AutoEcoFarmStopToWork"
        ]
    },
    "_AutoEcoFarmStopToWork": {
        "doc": "松开w防止有bug导致在移动状态",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 87 //w键
            }
        },
        "next": [
            //在停着的情况下直接识别，如果识别识别继续移动
            "[JumpBack]_AutoEcoFarmIsWorking",
            "_AutoEcoFarmFindMenuIcon",
            "_AutoEcoFarmJump"
        ]
    },
    "_AutoEcoFarmCancelMove": {
        "doc": "退出任务前先松开w",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 87 //w键
            }
        },
        "next": [
            "_AutoEcoFarmMoveAndWorkExit"
        ]
    },
    "_AutoEcoFarmIsWorking": {
        "doc": "识别是否正在工作，识别到就等30秒",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    557,
                    639,
                    165,
                    40
                ],
                "expected": [
                    "中"
                ],
                "threshold": 0.5
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": "等待30秒，让队友多干点活，不是脚本卡咯，别担心"
        },
        "pre_delay": 30000
    }
}

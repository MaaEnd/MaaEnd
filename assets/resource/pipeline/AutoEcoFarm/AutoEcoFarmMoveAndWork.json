//节点从Start进入，开始前要确保农田已被标记
//节点从Exit离开，这里关联下一个阶段的节点，里面的无限循环需要靠Maptracker检测坐标来退出
{ //节点出入口
    "_AutoEcoFarmMoveAndWorkStart": {
        "doc": "这块代码的目的是按下移动键，一边移动一边识别收菜菜单，识别到了就停下，点击收菜/播种/浇水",
        "next": [
            "_AutoEcoFarmChangeToWalk"
        ]
    },
    "_AutoEcoFarmMoveAndWorkExit": {
        "next": [
            "AutoEcoFarmMain"
        ]
    }
    //内部节点
    ,
    "_AutoEcoFarmChangeToWalk": {
        "doc": "按一下ctrl变成走路",
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 17 //ctrl键
            }
        },
        "next": [
            "_AutoEcoFarmMoveToTarget"
        ]
    },
    "_AutoEcoFarmMoveToTarget": {
        "doc": "长按w方向键朝目标前行,同时识别菜单",
        "action": {
            "type": "KeyDown",
            "param": {
                "key": 87 //w键
            }
        },
        "post_delay": 500,
        //最大连跑60秒，超过就直接结束任务
        "max_hit": 120,
        "next": [
            //识别失败的情况下判断是否还在农场内，如果不在则证明跑出农场了，结束该子任务
            "_AutoEcoFarmFindMenuIcon",
            "_AutoEcoFarmInAnyFarm",
            //不在的话结束任务
            "_AutoEcoFarmChangeToRun"
        ]
    },
    "_AutoEcoFarmInAnyFarm": {
        "doc": "确认是否在任意农场内",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "_AutoEcoFarmInValleyIVFarm",
                    "_AutoEcoFarmInWulinFarm"
                ]
            }
        },
        "inverse": true,
        "next": [
            "_AutoEcoFarmMoveToTarget",
            "_AutoEcoFarmMoveToTargetErr"
        ]
    },
    "_AutoEcoFarmInValleyIVFarm": {
        "doc": "确认是否在谷地农场内",
        "recognition": "Custom",
        "custom_recognition": "MapTrackerAssertLocation",
        "custom_recognition_param": {
            "expected": [
                {
                    "map_name": "map01_lv005",
                    "target": [
                        554,
                        325,
                        17,
                        18
                    ]
                }
            ]
        }
    },
    "_AutoEcoFarmInWulinFarm": {
        "doc": "确认是否在武陵农场内",
        "recognition": "Custom",
        "custom_recognition": "MapTrackerAssertLocation",
        "custom_recognition_param": {
            "expected": [
                {
                    "map_name": "map02_lv002",
                    "target": [
                        417,
                        167,
                        26,
                        25
                    ]
                }
            ]
        }
    },
    "_AutoEcoFarmFindMenuIcon": {
        "doc": "寻找采集、播种、浇水的按钮，都是同一个",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "sub_name": "icon",
                        "recognition": "TemplateMatch",
                        "roi": [
                            832,
                            455,
                            43,
                            40
                        ],
                        "template": "AutoEcoFarm/AutoEcoFarmHand.png",
                        "threshold": 0.9
                    },
                    {
                        "sub_name": "text",
                        "recognition": "OCR",
                        "roi": [
                            832,
                            455,
                            163,
                            40
                        ],
                        "expected": [
                            "[收获|育种|浇水]"
                        ],
                        "threshold": 0.7
                    }
                ]
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 70 //F键
            }
        },
        "next": [
            "_AutoEcoFarmStopToWork"
        ]
    },
    "_AutoEcoFarmStopToWork": {
        "doc": "松开w免得停不下来跑过头",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 87 //w键
            }
        },
        "next": [
            //在停着的情况下直接识别，如果识别识别继续移动
            "[JumpBack]_AutoEcoFarmIsWorking",
            "_AutoEcoFarmFindMenuIcon",
            "_AutoEcoFarmMoveToTarget"
        ]
    },
    "_AutoEcoFarmChangeToRun": {
        "doc": "按一下shift变回跑步",
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 16 //shift键
            }
        },
        "next": [
            "_AutoEcoFarmCancelMove"
        ]
    },
    "_AutoEcoFarmCancelMove": {
        "doc": "退出任务前先松开w",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 87 //w键
            }
        },
        "next": [
            "_AutoEcoFarmMoveAndWorkExit"
        ]
    },
    "_AutoEcoFarmIsWorking": {
        "doc": "识别是否正在工作，识别到就等20秒",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    557,
                    639,
                    165,
                    40
                ],
                "expected": [
                    "中"
                ],
                "threshold": 0.5
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": "等待20秒，让队友多干点活，不是脚本卡咯，别担心"
        },
        "pre_delay": 20000
    }
}

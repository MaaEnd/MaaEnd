    "AutoEssenceClickObtainButton": {
        "action": {
            "param": {
                "target_offset": [
                    -7,
                    15,
                    -7,
                    -60
                ]
            },
            "type": "Click"
        },
        "anchor": {
            "AutoEssenceAfterAltKeyUp": "AutoEssenceChooseScaling1"
        },
        "focus": {
            "Node.Action.Starting": "👆点击领取奖励按钮"
        },
        "next": [
            "AutoEssenceAltKeyUp"
        ],
        "recognition": {
            "param": {
                "roi": [
                    779,
                    395,
                    316,
                    196
                ],
                "expected": "领取奖励"
            },
            "type": "OCR"
        }
    },
    "AutoEssenceClickObtainButtonFailedPre": {
        "action": {
            "param": {
                "key": 18
            },
            "type": "KeyUp"
        },
        "focus": {
            "Node.Action.Starting": "❓未能找到领取奖励按钮"
        },
        "next": [
            "AutoEssenceClickObtainButtonFailed"

{
    "task": [
        {
            "description": "$task.AutoCollect.description",
            "entry": "AutoCollectEntry",
            "label": "$task.AutoCollect.label",
            "name": "AutoCollect",
            "option": [
                "AutoCollectThornyYazhen"
            ]
        }
    ],
    "option": {
        "AutoCollectThornyYazhen": {
            "type": "switch",
            "label": "$option.AutoCollectThornyYazhen.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoCollectEntry": {
                            "next": [
                                "AutoCollectHoldAlt"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AutoCollectEntry": {
                            "next": [
                                "AutoCollectEnd"
                            ]
                        }
                    }
                }
            ]
        }
    }
}

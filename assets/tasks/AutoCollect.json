{
    "task": [
        {
            "name": "AutoCollect",
            "label": "$task.AutoCollect.label",
            "entry": "AutoCollectStart",
            "description": "$task.AutoCollect.description",
            "option": [
                "CollectThornyYazhen"
            ]
        }
    ],
    "option": {
        "CollectThornyYazhen": {
            "type": "switch",
            "label": "$option.CollectThornyYazhen.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "CollectThornyYazhenSub": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "CollectThornyYazhenSub": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
